# EditorConfig - https://editorconfig.org
# Repo hygiene: keep every text file UTF-8 + LF so Windows/PowerShell tooling
# cannot silently reintroduce CRLF or corrupt the Arabic/glyph content.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Markdown uses two trailing spaces for hard line breaks - keep them intact.
[*.md]
trim_trailing_whitespace = false
